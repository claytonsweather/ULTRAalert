<!-- Alert Banner -->
<div id="alert-banner" style="
  background: #007bff;
  color: white;
  padding: 12px 48px 12px 16px;
  font-family: 'Segoe UI', sans-serif;
  font-size: 1rem;
  border-bottom: 3px solid #0056b3;
  cursor: pointer;
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 8px;
  min-height: 44px;
  box-sizing: border-box;
  transition: background-color 0.4s ease;
">
  <span style="flex-shrink:0; margin-top:2px;">⚠️</span>
  <div style="flex:1; min-width:0;">
    <span id="alert-headline" style="font-weight:600; display:block; word-wrap:break-word; white-space:normal; line-height:1.4;"></span>
    <span id="alert-location" style="font-size:0.8rem; opacity:0.85; display:block; margin-top:2px;"></span>
  </div>
  <span style="
    position:absolute;
    right:12px;
    top:50%;
    transform:translateY(-50%);
    font-size:0.75rem;
    opacity:0.85;
    background:rgba(255,255,255,0.2);
    padding:2px 8px;
    border-radius:4px;
    white-space:nowrap;
    font-weight:500;
  ">Tap for details</span>
</div>

<!-- Alert Modal -->
<div id="alert-modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.6); z-index:1000; justify-content:center; align-items:center;">
  <div style="
    background:white;
    max-width:640px;
    width:90%;
    border-radius:10px;
    box-shadow:0 8px 32px rgba(0,0,0,0.3);
    position:relative;
    overflow:hidden;
    max-height:90vh;
    display:flex;
    flex-direction:column;
  ">
    <!-- Modal Header -->
    <div id="modal-header" style="padding:16px 20px; border-bottom:1px solid #eee; flex-shrink:0;">
      <div style="display:flex; align-items:center; gap:10px; margin-bottom:4px;">
        <span id="modal-severity-badge" style="font-size:0.7rem; font-weight:700; padding:3px 10px; border-radius:20px; text-transform:uppercase; letter-spacing:0.05em; color:white;"></span>
        <span id="modal-counter" style="font-size:0.75rem; color:#999;"></span>
      </div>
      <h2 id="modal-title" style="margin:0; font-size:1.1rem; font-weight:700; color:#222; line-height:1.4;"></h2>
    </div>
    <!-- Modal Body (scrollable) -->
    <div style="padding:16px 20px; overflow-y:auto; flex:1;">
      <p id="modal-location" style="font-size:0.82rem; color:#888; margin:0 0 12px 0; font-style:italic;">📍 <span id="modal-location-text"></span></p>
      <p id="modal-desc" style="font-size:0.93rem; color:#333; line-height:1.65; margin:0 0 16px 0; white-space:pre-wrap;"></p>
      <a id="modal-link" href="#" target="_blank" style="
        display:inline-flex;
        align-items:center;
        gap:6px;
        color:white;
        background:#007bff;
        text-decoration:none;
        padding:8px 16px;
        border-radius:6px;
        font-size:0.88rem;
        font-weight:600;
      ">🔗 View Full NWS Alert</a>
    </div>
    <!-- Modal Nav Footer -->
    <div style="padding:12px 20px; border-top:1px solid #eee; display:flex; justify-content:space-between; align-items:center; flex-shrink:0; background:#fafafa;">
      <button onclick="navigateModal(-1)" style="background:#e9ecef; border:none; padding:7px 14px; border-radius:6px; cursor:pointer; font-size:0.85rem; font-weight:600;">← Prev</button>
      <span id="modal-nav-label" style="font-size:0.8rem; color:#888;"></span>
      <button onclick="navigateModal(1)" style="background:#e9ecef; border:none; padding:7px 14px; border-radius:6px; cursor:pointer; font-size:0.85rem; font-weight:600;">Next →</button>
    </div>
    <button onclick="closeModal()" style="position:absolute; top:10px; right:12px; background:none; border:none; font-size:22px; color:#aaa; cursor:pointer; line-height:1;">&times;</button>
  </div>
</div>

<script>
  const alertBanner   = document.getElementById('alert-banner');
  const alertHeadline = document.getElementById('alert-headline');
  const alertLocation = document.getElementById('alert-location');

  const modal           = document.getElementById('alert-modal');
  const modalHeader     = document.getElementById('modal-header');
  const modalTitle      = document.getElementById('modal-title');
  const modalDesc       = document.getElementById('modal-desc');
  const modalLocationEl = document.getElementById('modal-location-text');
  const modalLink       = document.getElementById('modal-link');
  const modalBadge      = document.getElementById('modal-severity-badge');
  const modalCounter    = document.getElementById('modal-counter');
  const modalNavLabel   = document.getElementById('modal-nav-label');

  let alerts = [];
  let bannerIndex = 0;
  let modalIndex  = 0;

  const severityColors = {
    'Severe':    '#dc3545',
    'Extreme':   '#9b0000',
    'Moderate':  '#fd7e14',
    'Minor':     '#d4a000',
    'Advisory':  '#17a2b8',
    'Watch':     '#fd7e14',
    'Emergency': '#dc3545',
    'Unknown':   '#007bff'
  };

  async function fetchAlerts() {
    try {
      const response = await fetch("https://api.weather.gov/alerts/active?area=TX");
      const data     = await response.json();

      if (!data.features || !data.features.length) {
        alerts = [{
          headline:    "No active alerts for Texas at this time.",
          severity:    'Unknown',
          area:        "Texas",
          description: "There are no current active alerts from the National Weather Service.",
          link:        "#"
        }];
      } else {
        alerts = data.features.map(f => {
          const p = f.properties;
          return {
            headline:    p.headline || p.event,
            severity:    p.severity || 'Unknown',
            area:        p.areaDesc || 'Unknown Area',
            description: p.description || 'No description provided.',
            link:        p.uri || "#"
          };
        });
      }

      bannerIndex = 0;
      updateBanner();
    } catch (err) {
      alerts = [{
        headline:    "Error loading alerts.",
        severity:    'Unknown',
        area:        "N/A",
        description: "Unable to fetch alerts at this time.",
        link:        "#"
      }];
      bannerIndex = 0;
      updateBanner();
      console.error(err);
    }
  }

  function updateBanner() {
    if (!alerts.length) return;
    const alert = alerts[bannerIndex];
    const color = severityColors[alert.severity] || severityColors['Unknown'];

    alertBanner.style.backgroundColor = color;
    alertBanner.style.borderBottomColor = darken(color);
    alertHeadline.textContent = alert.headline;
    alertLocation.textContent = alert.area;

    bannerIndex = (bannerIndex + 1) % alerts.length;
  }

  // Slightly darken a hex color for the border
  function darken(hex) {
    const n = parseInt(hex.replace('#',''), 16);
    const r = Math.max(0, (n >> 16) - 40);
    const g = Math.max(0, ((n >> 8) & 0xff) - 40);
    const b = Math.max(0, (n & 0xff) - 40);
    return `rgb(${r},${g},${b})`;
  }

  function showModal() {
    // Show the alert currently displayed on the banner
    modalIndex = (bannerIndex - 1 + alerts.length) % alerts.length;
    renderModal();
    modal.style.display = "flex";
  }

  function renderModal() {
    const alert = alerts[modalIndex];
    const color = severityColors[alert.severity] || severityColors['Unknown'];

    modalHeader.style.borderTop = `4px solid ${color}`;
    modalBadge.textContent      = alert.severity;
    modalBadge.style.background = color;
    modalCounter.textContent    = alerts.length > 1 ? `Alert ${modalIndex + 1} of ${alerts.length}` : '';
    modalTitle.textContent      = alert.headline;
    modalDesc.textContent       = alert.description;
    modalLocationEl.textContent = alert.area;
    modalLink.href              = alert.link;
    modalLink.style.background  = color;
    modalNavLabel.textContent   = `${modalIndex + 1} / ${alerts.length}`;
  }

  function navigateModal(dir) {
    modalIndex = (modalIndex + dir + alerts.length) % alerts.length;
    renderModal();
  }

  function closeModal() {
    modal.style.display = "none";
  }

  // Close modal on backdrop click
  modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });

  alertBanner.addEventListener('click', showModal);

  setInterval(updateBanner, 7000);
  setInterval(fetchAlerts, 10 * 60 * 1000);
  fetchAlerts();
</script>
